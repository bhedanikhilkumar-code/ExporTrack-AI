# Environment Variables for ExporTrack-AI

# API Configuration
VITE_API_BASE_URL=http://localhost:4000

# ============================================================================
# OTP Email Verification Configuration (Server-side)
# ============================================================================

# SendGrid Configuration (Recommended for reliable email delivery)
# Get your API key from: https://sendgrid.com/
# 1. Create SendGrid account
# 2. Go to Settings > API Keys
# 3. Create API Key with Mail Send permissions
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Alternative: Resend Configuration
# Get your API key from: https://resend.com/
# Note: Resend free tier includes 100 emails/month
RESEND_API_KEY=your_resend_api_key_here

# ============================================================================
# Email Verification API (Optional - for validating email exists)
# ============================================================================

# Email Verification API Key (Server-side)
EMAIL_VERIFICATION_API_KEY=your_email_verification_api_key_here
EMAIL_VERIFICATION_PROVIDER=abstract

# ============================================================================
# SMTP Configuration (Alternative - Not Recommended)
# ============================================================================

# Only use SMTP if you cannot use SendGrid or Resend
# For Gmail, you need an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=bhedanikhilkumar@gmail.com

# ============================================================================
# Other Configuration
# ============================================================================

# Google OAuth 2.0 Configuration
# Get your Client ID from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudflare Turnstile (for CAPTCHA)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Email Verification API Key (Frontend)
VITE_EMAIL_VERIFICATION_API_KEY=your_email_verification_api_key_here
VITE_EMAIL_VERIFICATION_PROVIDER=abstract
