# Environment Variables for ExporTrack-AI

# API Configuration
VITE_API_BASE_URL=http://localhost:4000

# Google OAuth 2.0 Configuration
# Get your Client ID from Google Cloud Console:
# 1. Go to https://console.cloud.google.com
# 2. Create/select a project
# 3. Enable Google Identity Service API
# 4. Create "OAuth 2.0 Client ID" (Web application)
# 5. Add authorized JavaScript origins: http://localhost:5173, http://localhost:5174, etc.
# 6. Add authorized redirect URIs: http://localhost:5173/dashboard, etc.
# 7. Copy the Client ID (looks like: XXXXXXXXXX-XXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google reCAPTCHA v3 Configuration
# Get your Site Key from https://www.google.com/recaptcha/admin/
# 1. Register a new site with reCAPTCHA v3
# 2. Add your domain(s) to the accepted domains list
# 3. Copy the Site Key (looks like: XXXXXXXXXX_XXXXXXXXXXXXXXXXXXXX)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Cloudflare Turnstile Configuration (Recommended - more user-friendly than reCAPTCHA)
# Get your Site Key from https://www.cloudflare.com/products/turnstile/
# 1. Add your site and get a Site Key
# 2. Copy the Site Key (looks like: 0x4AAAAAAA_XXXXXXXXXXXXXX)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Email Verification API (Optional - Abstract API or ZeroBounce)
# For enhanced security, you can integrate an email verification service
# Abstract API: https://www.abstractapi.com/api/email-verification
# ZeroBounce: https://www.zerobounce.net/
# Leave empty to disable email domain validation
VITE_EMAIL_VERIFICATION_API_KEY=your_email_verification_api_key_here
VITE_EMAIL_VERIFICATION_PROVIDER=abstract  # Options: abstract, zerobounce, or empty for disabled
